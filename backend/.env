# backend/.env

# Your Supabase connection string (replace with your actual password)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# OpenAI Key for the LLM and Embeddings
OPENAI_API_KEY="sk-your-openai-key-here"

# Server Port
PORT=8080
